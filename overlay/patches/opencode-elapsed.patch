From cd7f501e1734864850ffbe32d4956a4f785778fd Mon Sep 17 00:00:00 2001
From: Shogo Takata <shogo-takata@st.go.tuat.ac.jp>
Date: Thu, 9 Jul 2026 18:40:32 +0900
Subject: [PATCH] tui: show elapsed time on all spinners after 10s

Intent:
This patch enables elapsed time to be shown beside the spinner in tui views.

Update notes:
- Keep the elapsed-time logic in the shared TUI spinner component so every spinner in the TUI picks it up.
- Show the elapsed label only after 10 seconds.
- Use an explicit separator between the elapsed label and the spinner text; do not rely on trailing spaces in rendered text nodes.
- If this patch needs to be regenerated, create it from a clean opencode tree with git format-patch so the header stays in standard mail-format form.
- When updating to a newer opencode release, refresh the patch against the new source tree, then verify the resulting diff still only touches the spinner component.
- Do not wire elapsed time from tool-specific state; the spinner should own its own timer.
---
 packages/tui/src/component/spinner.tsx | 33 ++++++++++++++++++++++++--
 1 file changed, 31 insertions(+), 2 deletions(-)

diff --git a/packages/tui/src/component/spinner.tsx b/packages/tui/src/component/spinner.tsx
index 7007803..28b7b7c 100644
--- a/packages/tui/src/component/spinner.tsx
+++ b/packages/tui/src/component/spinner.tsx
@@ -1,4 +1,4 @@
-import { Show } from "solid-js"
+import { Show, createEffect, createSignal, onCleanup } from "solid-js"
 import { useTheme } from "../context/theme"
 import { useKV } from "../context/kv"
 import type { JSX } from "@opentui/solid"
@@ -7,14 +7,43 @@ import "opentui-spinner/solid"
 
 export const SPINNER_FRAMES = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
 
+// Show elapsed time on every spinner after it has been visible for 10s.
+function formatElapsed(seconds: number): string {
+  const h = Math.floor(seconds / 3600)
+  const m = Math.floor((seconds % 3600) / 60)
+  const s = seconds % 60
+  if (h > 0) return `${h}h ${m}m ${s}s`
+  if (m > 0) return `${m}m ${s}s`
+  return `${s}s`
+}
+
 export function Spinner(props: { children?: JSX.Element; color?: RGBA }) {
   const { theme } = useTheme()
   const kv = useKV()
   const color = () => props.color ?? theme.textMuted
+  const startedAt = Date.now()
+  const [elapsed, setElapsed] = createSignal(0)
+
+  createEffect(() => {
+    const update = () => setElapsed(Math.floor((Date.now() - startedAt) / 1000))
+    update()
+    const id = setInterval(update, 1000)
+    onCleanup(() => clearInterval(id))
+  })
+
+  const showElapsed = () => elapsed() >= 10
+  const separator = () => (showElapsed() && props.children ? " " : "")
+  const elapsedText = () => (showElapsed() ? formatElapsed(elapsed()) : "")
   return (
-    <Show when={kv.get("animations_enabled", true)} fallback={<text fg={color()}>⋯ {props.children}</text>}>
+    <Show when={kv.get("animations_enabled", true)} fallback={<text fg={color()}>⋯ {elapsedText()}{separator()}{props.children}</text>}>
       <box flexDirection="row" gap={1}>
         <spinner frames={SPINNER_FRAMES} interval={80} color={color()} />
+        <Show when={showElapsed()}>
+          <text fg={color()}>{formatElapsed(elapsed())}</text>
+        </Show>
+        <Show when={showElapsed() && props.children}>
+          <text fg={color()}> </text>
+        </Show>
         <Show when={props.children}>
           <text fg={color()}>{props.children}</text>
         </Show>
-- 
